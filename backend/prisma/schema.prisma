// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  passwordHash       String
  firstName          String
  lastName           String
  emailVerified      Boolean     @default(false)
  refreshToken       String?
  verificationToken  String?     @unique
  verificationExpiry DateTime?
  resetToken         String?     @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  portfolios         Portfolio[]
  progress           ModuleProgress[]
}

model Portfolio {
  id           String        @id @default(uuid())
  name         String
  description  String?
  userId       String
  cashBalance  Float         @default(10000)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions    Position[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  snapshots    PortfolioSnapshot[]

  @@index([userId])
}

model PortfolioSnapshot {
  id             String    @id @default(uuid())
  portfolioId    String
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  totalValue     Decimal   @db.Decimal(18, 2)
  cashBalance    Decimal   @db.Decimal(18, 2)
  positionsValue Decimal   @db.Decimal(18, 2)
  recordedAt     DateTime  @default(now())

  @@unique([portfolioId, recordedAt])
  @@index([portfolioId])
  @@index([recordedAt])
}

model Position {
  id             String       @id @default(uuid())
  symbol         String
  quantity       Decimal      @db.Decimal(18, 8)
  avgCost        Decimal      @db.Decimal(18, 2)
  positionType   PositionType @default(STOCK)
  optionType     OptionType?
  strikePrice    Decimal?     @db.Decimal(18, 2)
  expirationDate DateTime?
  contractSymbol String?
  status         PositionStatus @default(OPEN)
  portfolioId    String
  portfolio      Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([portfolioId, symbol, positionType, strikePrice, expirationDate])
  @@index([portfolioId])
  @@index([expirationDate])
  @@index([status])
}

model Transaction {
  id             String          @id @default(uuid())
  type           TransactionType
  symbol         String
  quantity       Decimal         @db.Decimal(18, 8)
  price          Decimal         @db.Decimal(18, 2)
  positionType   PositionType    @default(STOCK)
  optionType     OptionType?
  strikePrice    Decimal?        @db.Decimal(18, 2)
  expirationDate DateTime?
  contractSymbol String?
  portfolioId    String
  portfolio      Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  executedAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([portfolioId])
  @@index([symbol])
  @@index([positionType])
}

model Module {
  id          String           @id @default(uuid())
  title       String
  description String
  order       Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  progress    ModuleProgress[]
}

model ModuleProgress {
  id          String    @id @default(uuid())
  userId      String
  moduleId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, moduleId])
  @@index([userId])
}

enum PositionType {
  STOCK
  OPTION
}

enum OptionType {
  CALL
  PUT
}

enum PositionStatus {
  OPEN
  CLOSED
  EXPIRED
  EXERCISED
}

enum TransactionType {
  BUY
  SELL
  EXERCISE
  EXPIRED_WORTHLESS
  EXPIRATION
}
