# Copy this file to .env and fill in your real secrets. Do NOT commit .env to version control.

# Server
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/invested

# JWT
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Massive (MassiveStock / Massive API)
MASSIVE_API_KEY=YOUR_MASSIVE_API_KEY_HERE
# Optional: custom base URL if Massive docs specify
MASSIVE_API_BASE=https://api.massive.com

# Other optional services
REDIS_URL=redis://localhost:6379
EMAIL_USER=
EMAIL_PASS=
