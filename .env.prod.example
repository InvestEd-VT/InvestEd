# Copy this file to .env.prod and fill in values for local production testing
# Never commit .env.prod to version control

DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/invested
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-strong-random-string
JWT_REFRESH_SECRET=replace-with-different-strong-random-string
PORT=5001
FRONTEND_URL=http://localhost:80
BACKEND_URL=http://localhost:5001
EMAIL_USER=
EMAIL_PASS=
MASSIVE_API_KEY=your-massive-api-key
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=invested
VITE_API_URL=http://localhost:5001/api/v1