# ============================================================
# InvestEd Production Environment Variables
# For local docker-compose.prod.yml testing only.
# In AWS, secrets are managed via SSM Parameter Store.
# Copy to .env.prod — NEVER commit to version control.
# ============================================================

# --- Docker Compose Services ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=invested

# --- Backend ---
NODE_ENV=production
PORT=5001
DATABASE_URL=postgresql://postgres:replace-with-strong-password@postgres:5432/invested
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-random-64-char-string
JWT_REFRESH_SECRET=replace-with-different-64-char-string
FRONTEND_URL=http://localhost:80
BACKEND_URL=http://localhost:5001
ALLOWED_ORIGINS=http://localhost:80,http://localhost:3000
MASSIVE_API_KEY=your-massive-api-key
EMAIL_USER=
EMAIL_PASS=

# --- Frontend Build ---
VITE_API_URL=http://localhost:5001/api/v1
