# ============================================================
# InvestEd Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# --- Server ---
NODE_ENV=development                          # development | production | test
PORT=5001                                     # Backend port
FRONTEND_URL=http://localhost:3000            # Used for CORS and email links
BACKEND_URL=http://localhost:5001             # Backend base URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173  # Comma-separated CORS origins

# --- Database (required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invested  # PostgreSQL connection string

# --- Redis (required) ---
REDIS_URL=redis://localhost:6379              # Redis connection string

# --- Authentication (required) ---
JWT_SECRET=replace-with-random-64-char-string          # Access token signing key
JWT_REFRESH_SECRET=replace-with-different-64-char-string  # Refresh token signing key
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Massive API (required for stock/options data) ---
MASSIVE_API_KEY=                              # Get from Massive API dashboard
MASSIVE_API_BASE=https://api.massive.com      # Base URL (usually default)

# --- Email (optional for dev, required for production) ---
EMAIL_USER=                                   # Gmail address for sending verification emails
EMAIL_PASS=                                   # Gmail App Password (NOT regular password)
# Setup: https://myaccount.google.com/apppasswords (requires 2FA enabled)

# ============================================================
# AWS Production — these are managed by SSM Parameter Store
# in production and injected by ECS at runtime.
# See: infrastructure/scripts/setup-secrets.sh
# ============================================================
